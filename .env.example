# ZETI UBA Analyzer 환경변수 템플릿
#
# 사용법:
#   1. cp .env.example .env
#   2. .env의 placeholder를 실제 값으로 채움
#   3. .env는 절대 git commit 금지 (.gitignore에 등록됨)
#   4. chmod 600 .env

# === Elasticsearch ===
ES_HOST=https://10.0.41.10:9200
ES_USER=elastic
ES_PASS=__REPLACE_WITH_ROTATED_PASSWORD__

# === Anthropic API ===
# Phase 3a: Claude Haiku 4.5, Phase 3b: Claude Sonnet 4.6
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-__REPLACE_WITH_YOUR_KEY__

# === Slack ===
# Phase 4 발송용 — 채널 권장 #zetty-uba-alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/__T__/__B__/__SECRET__
