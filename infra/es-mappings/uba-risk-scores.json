{
  "index_patterns": ["uba-risk-scores-*"],
  "_meta": {
    "description": "Phase 2 출력. 8 팩터 산출 + final_score + dominant + attacker_level + exfil flag. v10: F9 soft cap 추적 필드 포함.",
    "spec_version": "v10",
    "spec_version_notes": "v9 §6.4 base + v10 F9 soft cap (f9_raw_score/f9_capped/f9_cap_reason) + target_type/target_id 통일 (score_target_type → target_type)",
    "owner_track": "B (UBA 코어 — factor_engine)",
    "consumers": ["C (Phase 3a llm_agent es_tool, Phase 3b intelligence_runner)", "A (Phase 5 Grafana 패널 1/2/4/5/8/9/10/11)"]
  },
  "template": {
    "settings": {
      "index.lifecycle.name": "uba-risk-scores-policy",
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "5s"
    },
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "@timestamp": {
          "type": "date"
        },

        "window_start": {
          "type": "date"
        },
        "window_end": {
          "type": "date"
        },
        "window_size": {
          "type": "keyword"
        },

        "target_type": {
          "type": "keyword"
        },
        "target_id": {
          "type": "keyword"
        },

        "total_score": {
          "type": "integer"
        },
        "dominant_factor": {
          "type": "keyword"
        },

        "factor_breakdown": {
          "type": "object",
          "properties": {
            "F2": {
              "type": "integer"
            },
            "F3": {
              "type": "integer"
            },
            "F5": {
              "type": "integer"
            },
            "F6": {
              "type": "integer"
            },
            "F7": {
              "type": "integer"
            },
            "F9": {
              "type": "integer"
            },
            "F_Resp": {
              "type": "integer"
            },
            "F_Cum": {
              "type": "integer"
            }
          }
        },

        "f9_raw_score": {
          "type": "integer"
        },
        "f9_capped": {
          "type": "boolean"
        },
        "f9_cap_reason": {
          "type": "keyword"
        },
        "f9_unique_subs_raw": {
          "type": "integer"
        },
        "f9_zscore": {
          "type": "double"
        },
        "f9_baseline_mean": {
          "type": "double"
        },
        "f9_baseline_std": {
          "type": "double"
        },
        "f9_baseline_sample_count": {
          "type": "long"
        },
        "f9_cold_start_fallback_applied": {
          "type": "boolean"
        },

        "attacker_level": {
          "type": "keyword"
        },
        "attacker_level_rationale": {
          "type": "keyword"
        },

        "data_exfiltration_detected": {
          "type": "boolean"
        },
        "suspected_exfiltration": {
          "type": "boolean"
        },
        "exfil_evidence": {
          "type": "object",
          "properties": {
            "pii_pattern_counts": {
              "type": "object",
              "properties": {
                "ssn": {
                  "type": "long"
                },
                "card": {
                  "type": "long"
                },
                "email": {
                  "type": "long"
                },
                "phone": {
                  "type": "long"
                }
              }
            },
            "response_bytes_total": {
              "type": "long"
            },
            "low_entropy_response_count": {
              "type": "long"
            }
          }
        },

        "ip_class": {
          "type": "keyword"
        },
        "ip_asn": {
          "type": "keyword"
        },
        "ip_org": {
          "type": "keyword"
        },
        "ip_country": {
          "type": "keyword"
        },
        "is_nat_whitelisted": {
          "type": "boolean"
        },

        "triggered_rules": {
          "type": "keyword"
        },
        "mapped_cve": {
          "type": "keyword"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "f5_violating_paths": {
              "type": "keyword"
            },
            "f5_unique_other_subs": {
              "type": "long"
            },
            "f6_max_ips_per_jti": {
              "type": "long"
            },
            "f6_jti_count_with_multi_ip": {
              "type": "long"
            },
            "f6_violating_samples": {
              "type": "nested",
              "properties": {
                "jti": {
                  "type": "keyword"
                },
                "ip_count": {
                  "type": "long"
                },
                "ip_set": {
                  "type": "keyword"
                }
              }
            },
            "sample_log_ids": {
              "type": "keyword"
            },
            "sample_uris": {
              "type": "keyword"
            }
          }
        },

        "is_baseline_eligible": {
          "type": "boolean"
        },
        "baseline_exclusion_reason": {
          "type": "keyword"
        },

        "computed_at": {
          "type": "date"
        },
        "factor_engine_version": {
          "type": "keyword"
        },
        "source_events_doc_id": {
          "type": "keyword"
        }
      }
    }
  }
}
